# Backend environment variables
# CRITICAL: This file is an EXAMPLE. Copy to .env and fill in real values.
# NEVER commit .env file to version control (it's in .gitignore)
# NEVER share .env contents publicly or via email
#
# Instructions:
#   1. Copy this file: cp .env.example .env
#   2. Fill in all values below with your actual configuration
#   3. Keep .env file secure and backed up
#   4. Rotate secrets periodically (90 days recommended)
#   5. Restart server after changes: npm start

# ───────────────────────────────────────────────────────────────────────────
# SECURITY: Environment & Node Settings
# ───────────────────────────────────────────────────────────────────────────
# Deployment environment (development | staging | production)
# Production enables strict security checks and hides error details
NODE_ENV=development

# ───────────────────────────────────────────────────────────────────────────
# Gemini AI API Configuration
# CRITICAL: Protect this key like a password
# Get from: https://ai.google.dev/
# ⚠️ DO NOT share or commit this key
# 🔄 Rotate monthly and enable key restrictions in Google Cloud Console
# ───────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ───────────────────────────────────────────────────────────────────────────
# Server Configuration
# ───────────────────────────────────────────────────────────────────────────
# Port the Express server runs on
# Production: Use environment-provided port
PORT=5000

# ───────────────────────────────────────────────────────────────────────────
# CORS Configuration (Cross-Origin Resource Sharing)
# CRITICAL: Restrict to your frontend domain only
# 
# Development: http://localhost:3000,http://127.0.0.1:3000
# Production: https://yourdomain.com (NO localhost)
# 
# Multiple origins: https://app.example.com,https://admin.example.com
# ───────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ───────────────────────────────────────────────────────────────────────────
# Firebase Configuration
# CRITICAL: Service account credentials grant full access to your Firebase project
# 
# Option 1: Environment Variable (Recommended for Production/CI-CD)
# Set FIREBASE_SERVICE_ACCOUNT to the full JSON content as a string:
#   FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...",...}'
#
# Option 2: Local File (Development only)
# Keep serviceAccountKey.json in backend/ directory
# Make sure it's in .gitignore (NEVER commit)
#
# DO NOT mix both options - use environment variable for production
# 🔄 Rotate service account keys every 90 days
# ───────────────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT=

# ───────────────────────────────────────────────────────────────────────────
# Security Configuration
# ───────────────────────────────────────────────────────────────────────────
# Enable rate limiting (development: can disable for testing)
RATE_LIMIT_ENABLED=true

# Enable HTTPS redirect in production
HTTPS_ENABLED=true

# Enable CSRF protection
CSRF_ENABLED=true

# Session timeout (milliseconds)
SESSION_TIMEOUT=3600000

# ───────────────────────────────────────────────────────────────────────────
# Logging & Monitoring
# ───────────────────────────────────────────────────────────────────────────
# Log level (error | warn | info | debug)
LOG_LEVEL=info

# Enable security audit logging
AUDIT_LOGGING_ENABLED=true

# Audit log retention (days before deletion)
AUDIT_LOG_RETENTION=90

# ───────────────────────────────────────────────────────────────────────────
# Email Configuration (for user notifications - optional)
# ───────────────────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ───────────────────────────────────────────────────────────────────────────
# Database Configuration (Future - currently using Firebase Firestore)
# ───────────────────────────────────────────────────────────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=health_assistant
# DB_USER=health_user
# DB_PASSWORD=secure-password-here

# ───────────────────────────────────────────────────────────────────────────
# SECURITY BEST PRACTICES
# ───────────────────────────────────────────────────────────────────────────
# ✓ Store in secure secret management tool (AWS Secrets Manager, Vault, etc.)
# ✓ Use strong, random values (32+ characters for keys)
# ✓ Different keys for different environments (dev/staging/prod)
# ✓ Enable key rotation policies
# ✓ Monitor key usage for anomalies
# ✓ Revoke and regenerate compromised keys immediately
# ✓ Never share .env files via email or chat
# ✓ Use SSH/secure channels for environment variable updates
# ✓ Enable MFA on service accounts
# ✓ Audit all key access and changes


