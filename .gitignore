# ─── Dependencies ────────────────────────────────────────────────────────
build/
node_modules/
/backend/node_modules/
/frontend/node_modules/
package-lock.json
yarn.lock

# ─── Cache & Temporary Files ─────────────────────────────────────────────
.cache/
*.cache
.eslintcache
.browserslistrc

# ─── CRITICAL: Environment Variables (NEVER COMMIT) ─────────────────────
# These contain sensitive credentials, API keys, secrets
.env
.env.local
.env.*.local
.env.production.local
.env.development.local

# ─── CRITICAL: Firebase Service Account (NEVER COMMIT) ──────────────────
# Contains full access credentials to Firebase project
serviceAccountKey.json
*serviceAccountKey*.json
firebase-key*.json
*-firebase-key.json

# ─── CRITICAL: Private Keys & Certificates ───────────────────────────────
*.pem
*.key
*.private
*.keystore
*.pfx

# ─── Logs & Audit Trails (Sensitive Information) ──────────────────────────
*.log
*.log.*
logs/
audit.log
access.log
error.log

# ─── OS Specific Files ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
desktop.ini

# ─── IDE & Editor Configuration ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
*.sublime-workspace
.vim/
.vimrc

# ─── Build & Distribution Outputs ────────────────────────────────────────
/build/
/dist/
/out/
*.bundle
*.min.js
*.min.css

# ─── React Specific ──────────────────────────────────────────────────────
/frontend/build/
/frontend/public/favicon.ico

# ─── Node Specific ───────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Temporary Test Files ────────────────────────────────────────────────
.nyc_output/
coverage/
*.tmp

# ─── Backups & Restore Points ────────────────────────────────────────────
*.backup
*.bak
*.restore
*.old

# ─── System Generated Files ──────────────────────────────────────────────
.versioninfo
thumbs.db

# ─── Local Development Only ──────────────────────────────────────────────
/node_modules
.nyc_output
coverage
dist
build
npm-debug.log

