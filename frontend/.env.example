# Frontend environment variables (React CRA — prefix with REACT_APP_)
# SAFE TO EXPOSE: These are public keys
# 
# Instructions:
#   1. Copy this file: cp .env.example .env
#   2. Fill in values from your Firebase project
#   3. Keep .env file - it's specific to your environment (not in .gitignore)
#   4. DO NOT commit to version control if you use different values per environment
#   5. Restart React dev server: npm start
#
# ⚠️ IMPORTANT: React builds include all REACT_APP_* vars in the JavaScript bundle
# This means these values ARE VISIBLE in the browser, so they must be public keys

# ───────────────────────────────────────────────────────────────────────────
# Backend API Configuration
# ───────────────────────────────────────────────────────────────────────────
# Development: http://localhost:5000
# Production: https://your-api-domain.com (MUST be HTTPS in production)
# Make sure this domain is whitelisted in backend ALLOWED_ORIGINS
REACT_APP_API_URL=http://localhost:5000

# ───────────────────────────────────────────────────────────────────────────
# Firebase Configuration
# Get values from Firebase Console → Project Settings → General
# https://console.firebase.google.com
# 
# These are PUBLIC credentials for your Firebase project
# They authenticate the CLIENT SIDE only
# Server-side authentication uses separate serviceAccountKey.json
# ───────────────────────────────────────────────────────────────────────────

# Web API Key (public, doesn't grant privileges)
# Found in: Firebase Console → Project Settings → Your web app
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key

# Firebase Auth Domain (required for auth flows)
# Format: your-project.firebaseapp.com
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Firebase Project ID
# Found in: Firebase Console → Project Settings
REACT_APP_FIREBASE_PROJECT_ID=your-project-id

# Firebase Storage Bucket (for file uploads)
# Format: your-project.appspot.com
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase Cloud Messaging Sender ID
# Found in: Firebase Console → Project Settings
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Firebase App ID
# Found in: Firebase Console → Project Settings
REACT_APP_FIREBASE_APP_ID=your_app_id

# Firebase Measurement ID for Analytics
# Optional - can be empty if analytics not needed
REACT_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ───────────────────────────────────────────────────────────────────────────
# reCAPTCHA v2 Configuration (Optional - for form security)
# Prevents bot abuse on login/signup
# Get from: https://www.google.com/recaptcha/admin
# 
# Public site key (safe to expose)
# Private secret key: Store in backend .env ONLY, never in frontend
# ───────────────────────────────────────────────────────────────────────────
REACT_APP_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# ───────────────────────────────────────────────────────────────────────────
# SECURITY NOTES
# ───────────────────────────────────────────────────────────────────────────
# ✓ These values are PUBLIC and visible in the browser
# ✓ They represent client-side access only
# ✓ Server-side APIs authenticate with separate credentials
# ✓ Never put backend secrets (API keys, DB passwords) here
# ✓ HTTPS must be used in production (Content-Security-Policy enforced)
# ✓ Firebase rules restrict access to authenticated users only
# ✓ Auth tokens stored in sessionStorage (cleared on tab close)
# ✓ Detailed error messages shown in development only


